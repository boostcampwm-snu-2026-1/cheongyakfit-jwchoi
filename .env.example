# 복사해서 .env.local 로 만들고 값을 채운다 (.env.local 은 git 에 올리지 않음).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # 서버 전용 — 절대 클라이언트에 노출 금지

# --- 앱 ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # OAuth redirectTo / config.toml site_url

# --- OpenAI (서버 전용, PDF 파싱) ---
OPENAI_API_KEY=

# --- 카카오 OAuth (Supabase Auth provider) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
